{"cells":[{"cell_type":"markdown","source":["# ÁRBOLES DE BÚSQUEDA ABB Y B+\n","\n","\n","**PROBLEMA:** Sistema de Búsqueda de Estudiantes"],"metadata":{"id":"mh6yOHUu29ME"}},{"cell_type":"code","source":["import random\n","import time\n","\n","#   PASO 1: GENERAR 10,000 ESTUDIANTES ALEATORIAMENTE\n","\n","nombres = [\"Ana\",\"Carlos\",\"María\",\"Luis\",\"Sofía\",\"Pedro\",\n","           \"Laura\",\"Jorge\",\"Valeria\",\"Miguel\", \"Santiago\",\"Clara\",\"Esteban\",\"Michael\",\"Melany\",\"Genesis\",\"Carlos\",\"Ester\"]\n","\n","# Genera estudiantes hasta tener exactamente 10,000 únicos\n","estudiantes_dict = {}\n","while len(estudiantes_dict) < 10000:\n","    id = random.randint(1000, 99999)  # rango más amplio para evitar colisiones\n","    if id not in estudiantes_dict:\n","        estudiantes_dict[id] = {\n","            \"id\": id,\n","            \"nombre\": random.choice(nombres),\n","            \"promedio\": round(random.uniform(6.0, 10.0), 1)\n","        }\n","\n","estudiantes = list(estudiantes_dict.values())\n","# Elimina IDs duplicados\n","estudiantes = list({e[\"id\"]: e for e in estudiantes}.values())\n","\n","# ================================================================\n","#   PASO 2: ELEGIR ORDEN DE INSERCIÓN\n","#   segun el orden de los datos generados: Comenta/descomenta\n","# ================================================================\n","#estudiantes.sort(key=lambda e: e[\"id\"])   # ← IDs EN ORDEN\n","random.shuffle(estudiantes)             # ← IDs ALEATORIOS  -- IMPORTANTE\n","\n","print(f\"✅ {len(estudiantes)} estudiantes generados.\")\n","print(f\"Primeros 3: {[(e['id'], e['nombre']) for e in estudiantes[:3]]}\")\n","\n","# ================================================================\n","#   LISTA — búsqueda lineal (sin árbol)\n","\n","def buscar_lista(lista, id):\n","    for e in lista:       # recorre uno por uno\n","        if e[\"id\"] == id:\n","            return e\n","    return None\n","\n","ids_buscar = random.sample([e[\"id\"] for e in estudiantes], 100)\n","\n","inicio = time.time()\n","for id in ids_buscar:\n","    buscar_lista(estudiantes, id)\n","tiempo_lista = time.time() - inicio\n","\n","print(f\"\\n Lista     : {tiempo_lista:.4f} segundos (100 búsquedas)\")\n","\n","# ================================================================\n","#   ABB CON BALANCEO AVL\n","\n","class Nodo:\n","    def __init__(self, id, nombre, promedio):\n","        self.id = id; self.nombre = nombre; self.promedio = promedio\n","        self.izq = None; self.der = None; self.altura = 1\n","\n","def altura(n): return n.altura if n else 0\n","def factor(n): return altura(n.izq) - altura(n.der)\n","\n","def rotar_der(y):\n","    x = y.izq; y.izq = x.der; x.der = y\n","    y.altura = 1 + max(altura(y.izq), altura(y.der))\n","    x.altura = 1 + max(altura(x.izq), altura(x.der))\n","    return x\n","\n","def rotar_izq(x):\n","    y = x.der; x.der = y.izq; y.izq = x\n","    x.altura = 1 + max(altura(x.izq), altura(x.der))\n","    y.altura = 1 + max(altura(y.izq), altura(y.der))\n","    return y\n","\n","def balancear(nodo):\n","    # Recalcula altura y aplica rotación si está desbalanceado\n","    nodo.altura = 1 + max(altura(nodo.izq), altura(nodo.der))\n","    fb = factor(nodo)\n","    if fb > 1:\n","        if factor(nodo.izq) < 0: nodo.izq = rotar_izq(nodo.izq)\n","        return rotar_der(nodo)\n","    if fb < -1:\n","        if factor(nodo.der) > 0: nodo.der = rotar_der(nodo.der)\n","        return rotar_izq(nodo)\n","    return nodo\n","\n","def insertar_abb(nodo, id, nombre, promedio):\n","    if not nodo: return Nodo(id, nombre, promedio)\n","    if id < nodo.id:   nodo.izq = insertar_abb(nodo.izq, id, nombre, promedio)\n","    elif id > nodo.id: nodo.der = insertar_abb(nodo.der, id, nombre, promedio)\n","    return balancear(nodo)   # balancea en cada nivel al subir\n","\n","def buscar_abb(nodo, id):\n","    if not nodo: return None\n","    if id == nodo.id: return nodo\n","    return buscar_abb(nodo.izq, id) if id < nodo.id else buscar_abb(nodo.der, id)\n","\n","def listar_abb(nodo, lista=[]):\n","    # Recorrido en orden → da los IDs de menor a mayor\n","    if nodo:\n","        listar_abb(nodo.izq, lista)\n","        lista.append((nodo.id, nodo.nombre, nodo.promedio))\n","        listar_abb(nodo.der, lista)\n","    return lista\n","\n","# Construir árbol ABB con los 10,000 estudiantes\n","import sys\n","sys.setrecursionlimit(20000)   # necesario para 10k nodos\n","\n","raiz_abb = None\n","for e in estudiantes:\n","    raiz_abb = insertar_abb(raiz_abb, e[\"id\"], e[\"nombre\"], e[\"promedio\"])\n","\n","# Medir 100 búsquedas aleatorias\n","inicio = time.time()\n","for id in ids_buscar:\n","    buscar_abb(raiz_abb, id)\n","tiempo_abb = time.time() - inicio\n","\n","print(f\" ABB (AVL) : {tiempo_abb:.4f} segundos (100 búsquedas)\")\n","\n","# ================================================================\n","#   ÁRBOL B+\n","\n","ORDEN = 50   # nodos más grandes → menos niveles → más rápido\n","\n","class NodoBP:\n","    def __init__(self, hoja=False):\n","        self.hoja = hoja\n","        self.claves = []; self.hijos = []\n","        self.siguiente = None   # enlace entre hojas para listar en orden\n","\n","class ArbolBPlus:\n","    def __init__(self): self.raiz = NodoBP(hoja=True)\n","\n","    def buscar(self, id):\n","        nodo = self.raiz\n","        while not nodo.hoja:   # baja por nodos internos\n","            i = 0\n","            while i < len(nodo.claves) and id >= nodo.claves[i]: i += 1\n","            nodo = nodo.hijos[i]\n","        for i, c in enumerate(nodo.claves):\n","            if c == id: return nodo.hijos[i]\n","        return None\n","\n","    def insertar(self, id, datos):\n","        res = self._ins(self.raiz, id, datos)\n","        if res:   # si la raíz se dividió, crea nueva raíz\n","            nueva = NodoBP()\n","            nueva.claves = [res[0]]; nueva.hijos = [self.raiz, res[1]]\n","            self.raiz = nueva\n","\n","    def _ins(self, nodo, id, datos):\n","        if nodo.hoja:\n","            i = 0\n","            while i < len(nodo.claves) and id > nodo.claves[i]: i += 1\n","            nodo.claves.insert(i, id); nodo.hijos.insert(i, datos)\n","            if len(nodo.claves) >= ORDEN: return self._div_hoja(nodo)\n","        else:\n","            i = 0\n","            while i < len(nodo.claves) and id >= nodo.claves[i]: i += 1\n","            res = self._ins(nodo.hijos[i], id, datos)\n","            if res:\n","                nodo.claves.insert(i, res[0]); nodo.hijos.insert(i+1, res[1])\n","                if len(nodo.claves) >= ORDEN: return self._div_int(nodo)\n","        return None\n","\n","    def _div_hoja(self, nodo):\n","        mid = len(nodo.claves)//2\n","        nuevo = NodoBP(hoja=True)\n","        nuevo.claves = nodo.claves[mid:]; nuevo.hijos = nodo.hijos[mid:]\n","        nodo.claves  = nodo.claves[:mid]; nodo.hijos  = nodo.hijos[:mid]\n","        nuevo.siguiente = nodo.siguiente; nodo.siguiente = nuevo\n","        return (nuevo.claves[0], nuevo)\n","\n","    def _div_int(self, nodo):\n","        mid = len(nodo.claves)//2\n","        nuevo = NodoBP()\n","        nuevo.claves = nodo.claves[mid+1:]; nuevo.hijos = nodo.hijos[mid+1:]\n","        c = nodo.claves[mid]\n","        nodo.claves = nodo.claves[:mid];    nodo.hijos  = nodo.hijos[:mid+1]\n","        return (c, nuevo)\n","\n","    def listar(self):\n","        # Recorre las hojas enlazadas → orden ascendente por ID\n","        nodo = self.raiz\n","        while not nodo.hoja: nodo = nodo.hijos[0]\n","        res = []\n","        while nodo:\n","            for i, c in enumerate(nodo.claves): res.append((c, nodo.hijos[i]))\n","            nodo = nodo.siguiente\n","        return res\n","\n","# Construir árbol B+\n","arbol_bp = ArbolBPlus()\n","for e in estudiantes:\n","    arbol_bp.insertar(e[\"id\"], e)\n","\n","# Medir 100 búsquedas aleatorias\n","inicio = time.time()\n","for id in ids_buscar:\n","    arbol_bp.buscar(id)\n","tiempo_bplus = time.time() - inicio\n","\n","print(f\" B+        : {tiempo_bplus:.4f} segundos (100 búsquedas)\")\n","\n","# ================================================================\n","#   RESULTADOS FINALES — igual al formato de la imagen\n","\n","print(\"\\n\" + \"=\"*55)\n","print(\"   Resultados para\", len(estudiantes), \"estudiantes:\")\n","print(\"=\"*55)\n","print(f\"  Lista  : {tiempo_lista:.4f} segundos\")\n","print(f\"  ABB    : {tiempo_abb:.4f} segundos  (¡{tiempo_lista/tiempo_abb:.0f}x más rápido!)\")\n","print(f\"  B+     : {tiempo_bplus:.4f} segundos  (similar a ABB, pero gana en rangos)\")\n","print(\"=\"*55)\n","\n","mas_rapido = min(tiempo_abb, tiempo_bplus)\n","if mas_rapido == tiempo_abb:\n","    print(\"   El más rápido fue: ABB (AVL)\")\n","else:\n","    print(\"   El más rápido fue: B+\")\n","print(\"=\"*55)\n","\n","# ================================================================\n","#   LISTAR primeros 5 en orden por ID (ambos árboles)\n","\n","print(\"\\n Primeros 5 en orden — ABB:\")\n","for f in listar_abb(raiz_abb, [])[:5]:\n","    print(f\"  ID: {f[0]} | Nombre: {f[1]} | Promedio: {f[2]}\")\n","\n","print(\"\\n Primeros 5 en orden — B+:\")\n","for c, d in arbol_bp.listar()[:5]:\n","    print(f\"  ID: {c} | Nombre: {d['nombre']} | Promedio: {d['promedio']}\")"],"metadata":{"id":"LqFMphYs3sOa","executionInfo":{"status":"ok","timestamp":1773602393699,"user_tz":300,"elapsed":236,"user":{"displayName":"","userId":""}},"outputId":"5c8a71dd-78c3-4ee3-e1ea-f982229be2ea","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ 10000 estudiantes generados.\n","Primeros 3: [(44599, 'Genesis'), (69081, 'Esteban'), (7109, 'Melany')]\n","\n"," Lista     : 0.0435 segundos (100 búsquedas)\n"," ABB (AVL) : 0.0003 segundos (100 búsquedas)\n"," B+        : 0.0004 segundos (100 búsquedas)\n","\n","=====================================